SERVER_PORT=2026

DB_URL=jdbc:h2:mem:authdb;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
DB_DRIVER=org.h2.Driver
DB_USERNAME=sa
DB_PASSWORD=

JPA_PLATFORM=org.hibernate.dialect.H2Dialect
JPA_DDL_AUTO=create-drop
JPA_SHOW_SQL=false

# Generate a strong random string of >= 32 characters and paste it here
JWT_SECRET=your-super-secret-key-min-32-chars-here
JWT_EXPIRATION_MS=86400000
JWT_ISSUER=sample-application

LOG_LEVEL_APP=DEBUG
LOG_LEVEL_SECURITY=INFO