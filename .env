# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=2026

# ── Database ──────────────────────────────────────────────────────────────────
DB_URL=jdbc:h2:mem:authdb;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
DB_DRIVER=org.h2.Driver
DB_USERNAME=sa
DB_PASSWORD=

# ── JPA ───────────────────────────────────────────────────────────────────────
JPA_PLATFORM=org.hibernate.dialect.H2Dialect
JPA_DDL_AUTO=create-drop
JPA_SHOW_SQL=false

# ── Security / JWT ────────────────────────────────────────────────────────────
# Must be >= 32 characters for HMAC-SHA256
JWT_SECRET=a9F3kLmP8xQ2zR7tV4nY6wB1cD5eH0jK
JWT_EXPIRATION_MS=86400000
JWT_ISSUER=sample-application

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL_APP=DEBUG
LOG_LEVEL_SECURITY=INFO